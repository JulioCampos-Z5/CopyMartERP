# ========================================
# CopyMart ERP - Variables de Entorno
# ========================================
#
# BACKEND  (raíz del proyecto)
#   venv\Scripts\activate
#   python app/main.py
#
# FRONTEND  (copy-mart/)
#   npm run dev
#
# ────────────────────────────────────────

# Base de datos
DATABASE_URL=mysql+pymysql://usuario:contraseña@localhost:3306/copymart

# JWT
SECRET_KEY=cambia_esta_clave_secreta
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480

# Servidor
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000

# Correo para recuperación de contraseña (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=

# IP local del servidor (para acceso desde otros dispositivos en la red)
# Cambia esto por la IP de tu PC: ejecuta `ipconfig` y busca "Dirección IPv4"
LOCAL_IP=192.168.1.10

# Frontend — apunta a la IP local del servidor para que otros dispositivos puedan conectarse
# En desarrollo local puedes dejar localhost; para red local usa la IP de este equipo
VITE_API_URL=http://localhost:8000
