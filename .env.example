# ========================================
# CopyMart ERP - Variables de Entorno (Ejemplo)
# ========================================

# Base de datos
DATABASE_URL=mysql+pymysql://usuario:contraseña@localhost:3306/copymart

# JWT
SECRET_KEY=cambia_esta_clave_secreta
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480

# Servidor
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000

# Correo para recuperación de contraseña (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=

# Frontend
VITE_API_URL=http://localhost:8000
